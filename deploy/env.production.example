# Production environment variables for E4RTH
# Fill these with the real values from Neon, Upstash, Northflank, Vercel, and external API providers.

## Frontend (Vercel) - public variables start with NEXT_PUBLIC_
# Public keys used by client-side code
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_API_URL=https://api.e4rth.example.com

## Backend (Northflank) - server-side secrets
DATABASE_URL=postgresql://<user>:<pass>@<host>:5432/<db>?sslmode=require
REDIS_URL=redis://:<password>@<host>:6379/0
JWT_SECRET_KEY=replace-with-long-random-secret
SENTRY_DSN=

# External API keys used by backend services
OPENAI_API_KEY=
IQAIR_API_KEY=
COPERNICUS_API_KEY=
MAPBOX_TOKEN=

## Optional / feature flags
ENVIRONMENT=production
ADMIN_EMAIL=

# CI / Registry
GHCR_PAT=

# Notes:
# - Do NOT commit real secrets. Use the provider secret store (Vercel, Northflank, GitHub Secrets).
# - `NEXT_PUBLIC_*` vars are exposed to the browser. Do not put private keys there.
