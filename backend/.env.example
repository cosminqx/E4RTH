PORT=5001
NODE_ENV=development
OPENAQ_API_KEY=your_openaq_api_key_here
# Neon pooled connection string (recommended in production)
DATABASE_URL=postgresql://<user>:<password>@<endpoint-pooler>.neon.tech/neondb?sslmode=require

# Optional: local source database used by db:copy:local-to-neon
LOCAL_DATABASE_URL=postgresql://<local_user>@localhost:5432/e4rth_dev
